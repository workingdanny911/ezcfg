{
  "name": "ezcfg",
  "version": "0.3.1",
  "type": "module",
  "description": "Lite and easy configuration management for Node.js",
  "license": "MIT",
  "author": "Sangwoo Hyun <wkdny.hyun@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "config",
    "configuration",
    "env",
    "environment",
    "typescript",
    "type-safe"
  ]
}
